POB_ENGINE_URL=http://127.0.0.1:4317
POB_ENGINE_TOKEN=local-development-token

# Add the same REST database to Vercel and the Hugging Face Space to enable
# durable asynchronous comparisons. Without these values, local development
# keeps using the original direct streaming request.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
POB_ASYNC_QUEUE_PREFIX=poe-upgrade-optimizer:v1
POB_ASYNC_MAX_QUEUED_JOBS=100
POB_ASYNC_JOB_TTL_SECONDS=86400
